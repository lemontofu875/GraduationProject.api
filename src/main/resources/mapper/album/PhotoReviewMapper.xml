<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.youlai.boot.platform.album.mapper.PhotoReviewMapper">

    <resultMap id="PhotoReviewPageVOMap" type="com.youlai.boot.platform.album.model.vo.PhotoReviewPageVO">
        <id column="id" property="id"/>
        <result column="album_id" property="albumId"/>
        <result column="album_name" property="albumName"/>
        <result column="original_name" property="originalName"/>
        <result column="file_url" property="fileUrl"/>
        <result column="file_size" property="fileSize"/>
        <result column="review_summary" property="reviewSummary"/>
        <result column="review_rating" property="reviewRating"/>
        <result column="review_time" property="reviewTime"/>
    </resultMap>

    <resultMap id="PhotoReviewDetailVOMap" type="com.youlai.boot.platform.album.model.vo.PhotoReviewDetailVO">
        <id column="id" property="id"/>
        <result column="album_id" property="albumId"/>
        <result column="album_name" property="albumName"/>
        <result column="original_name" property="originalName"/>
        <result column="file_path" property="filePath"/>
        <result column="file_url" property="fileUrl"/>
        <result column="file_size" property="fileSize"/>
        <result column="exif_info" property="exifInfo" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result column="review_summary" property="reviewSummary"/>
        <result column="review_advantages" property="reviewAdvantages"/>
        <result column="review_disadvantages" property="reviewDisadvantages"/>
        <result column="review_rating" property="reviewRating"/>
        <result column="review_time" property="reviewTime"/>
    </resultMap>

    <select id="getPhotoReviewPage" resultMap="PhotoReviewPageVOMap">
        SELECT
            pr.id,
            pr.album_id,
            a.name AS album_name,
            pr.original_name,
            pr.file_url,
            pr.file_size,
            pr.review_summary,
            pr.review_rating,
            pr.review_time
        FROM photo_review pr
        LEFT JOIN album a ON a.id = pr.album_id
        ORDER BY pr.review_time DESC, pr.id DESC
    </select>

    <select id="getPhotoReviewDetail" resultMap="PhotoReviewDetailVOMap">
        SELECT
            pr.id,
            pr.album_id,
            a.name AS album_name,
            pr.original_name,
            pr.file_path,
            pr.file_url,
            pr.file_size,
            pr.exif_info,
            pr.review_summary,
            pr.review_advantages,
            pr.review_disadvantages,
            pr.review_rating,
            pr.review_time
        FROM photo_review pr
        LEFT JOIN album a ON a.id = pr.album_id
        WHERE pr.id = #{id}
    </select>
</mapper>
